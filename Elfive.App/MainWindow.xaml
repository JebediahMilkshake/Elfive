<Window x:Class="Elfive.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Elfive.App"
        xmlns:views="clr-namespace:Elfive.App.Views"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        WindowState="Maximized">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open" Click="MenuOpen_Click"/>
            </MenuItem>
        </Menu>
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding ControllerName}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding ProcessorType}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding TagCount, StringFormat='{}{0} tags'}"/>
            </StatusBarItem>
        </StatusBar>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left sidebar: project tree -->
            <TreeView Grid.Column="0"
                      ItemsSource="{Binding TreeItems}"
                      SelectedItemChanged="TreeView_SelectedItemChanged">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" Margin="4,2" />
                            <TextBlock Text="{Binding Detail}" Foreground="Gray"
                                       Margin="4,2" FontStyle="Italic" />
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <GridSplitter Grid.Column="1" Width="5"
                          HorizontalAlignment="Stretch"
                          Background="LightGray" />

            <!-- Right content area -->
            <ContentControl Grid.Column="2" Content="{Binding SelectedNode}">
                <ContentControl.Resources>

                    <!-- When nothing is selected -->
                    <DataTemplate x:Key="EmptyTemplate">
                        <TextBlock Text="Select an item from the tree"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="Gray" FontSize="16" />
                    </DataTemplate>

                    <!-- When a Program is selected or controller tags: -->
                    <DataTemplate x:Key="TagsTemplate">
                        <DockPanel>
                            <TextBox DockPanel.Dock="Top"
                                     Text="{Binding DataContext.TagFilter, 
                                        RelativeSource={RelativeSource AncestorType=Window},
                                        UpdateSourceTrigger=PropertyChanged}"
                                     Margin="4" Padding="4" />
                            <DataGrid
                                ItemsSource="{Binding DataContext.VisibleTags,
                              RelativeSource={RelativeSource AncestorType=Window}}"
                                AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="200" />
                                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="150" />
                                    <DataGridTextColumn Header="Data Type" Binding="{Binding DataType}" Width="120" />
                                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </DataTemplate>

                    <!-- When a Routine is selected: show its content -->
                    <DataTemplate x:Key="TextTemplate">
                        <views:TextViewer
                            RoutineContent="{Binding DataContext.SelectedRoutineContent,
                                RelativeSource={RelativeSource AncestorType=Window}}"
                            RoutineType="{Binding Detail}"/>
                    </DataTemplate>
                    
                    <DataTemplate x:Key="LadderTemplate">
                        <views:LadderViewer/>
                    </DataTemplate>

                    <!-- When a Module is selected: show its details -->
                    <DataTemplate x:Key="ModuleTemplate">
                        <StackPanel Margin="16">
                            <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" />
                            <TextBlock Text="{Binding Detail}" Foreground="Gray" Margin="0,4,0,0" />
                        </StackPanel>
                    </DataTemplate>

                </ContentControl.Resources>
                <ContentControl.ContentTemplateSelector>
                    <local:NodeTemplateSelector
                        EmptyTemplate="{StaticResource EmptyTemplate}"
                        TagsTemplate="{StaticResource TagsTemplate}"
                        TextTemplate="{StaticResource TextTemplate}"
                        LadderTemplate="{StaticResource LadderTemplate}"
                        ModuleTemplate="{StaticResource ModuleTemplate}" />
                </ContentControl.ContentTemplateSelector>
            </ContentControl>
        </Grid>
    </DockPanel>
</Window>
